# ── Database ────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon recommended for production)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth (better-auth) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Your app's public URL (dev: your Replit dev domain, prod: your production domain)
BETTER_AUTH_URL="http://localhost:5000"
NEXT_PUBLIC_APP_URL="http://localhost:5000"

# ── AI (Google Gemini) ──────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── File storage (Cloudinary) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── OAuth providers (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Virus scanning (optional, disabled by default) ──────────────────────
# Set to "true" and wire a provider in src/lib/virus-scan.ts before enabling.
VIRUS_SCAN_ENABLED="false"
